{
  "name": "grd",
  "version": "0.1.1",
  "description": "Get Research Done — R&D workflow automation for Claude Code",
  "author": { "name": "Cameleon X" },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/grd-tools.js\" verify-path-exists .planning 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
